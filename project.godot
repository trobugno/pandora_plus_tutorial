; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pandora+ RPG Tutorial"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Pandora="*res://addons/pandora/api.gd"
PPCombatCalculator="*res://addons/pandora_plus/autoloads/PPCombatCalculator.gd"
PPInventoryUtils="*res://addons/pandora_plus/autoloads/PPInventoryUtils.gd"
PPRecipeUtils="*res://addons/pandora_plus/autoloads/PPRecipeUtils.gd"
PPQuestUtils="*res://addons/pandora_plus/autoloads/PPQuestUtils.gd"
PPNPCUtils="*res://addons/pandora_plus/autoloads/PPNPCUtils.gd"
PPPlayerManager="*res://addons/pandora_plus/managers/player_manager.gd"
PPQuestManager="*res://addons/pandora_plus/managers/quest_manager.gd"
PPNPCManager="*res://addons/pandora_plus/managers/npc_manager.gd"
PPTimeManager="*res://addons/pandora_plus/managers/time_manager.gd"
PPSaveManager="*res://addons/pandora_plus/save_system/save_manager.gd"
Globals="*res://utils/Globals.gd"
Dialogic="*res://addons/dialogic/Core/DialogicGameHandler.gd"

[dialogic]

directories/dch_directory={
"elara": "res://dialogic/characters/elara.dch",
"finn": "res://dialogic/characters/finn.dch",
"old_bram": "res://dialogic/characters/old_bram.dch",
"voss": "res://dialogic/characters/voss.dch"
}
directories/dtl_directory={
"elara_dialogue": "res://dialogic/dialogues/elara_dialogue.dtl",
"finn_dialogue": "res://dialogic/dialogues/finn_dialogue.dtl",
"old_bram_dialogue": "res://dialogic/dialogues/old_bram_dialogue.dtl"
}
layout/style_directory={}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=true
animations/leave_default_length=0.5
animations/leave_default_wait=true
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
}
}
animations/join_default="Fade In"
variables={
"Quests": {
"scout_the_crossing": 0,
"welcome_to_willowmere": 0
}
}

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg", "res://addons/pandora/plugin.cfg", "res://addons/pandora_plus/plugin.cfg")

[input]

toggle_inventory={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":73,"key_label":0,"unicode":105,"location":0,"echo":false,"script":null)
]
}
toggle_quests={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":79,"key_label":0,"unicode":111,"location":0,"echo":false,"script":null)
]
}
dialogic_default_action={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":32,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":88,"physical_keycode":0,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventJoypadButton,"resource_local_to_scene":false,"resource_name":"","device":0,"button_index":0,"pressure":0.0,"pressed":false,"script":null)
]
}

[pandora]

config/extensions=[&"res://pandora/extensions", &"res://addons/pandora_plus/extensions"]

[pandora_plus]

config/save_system/max_save_slots=1
config/save_system/autosave_enabled=false
config/player/max_inventory_slots=20

[rendering]

textures/canvas_textures/default_texture_filter=0

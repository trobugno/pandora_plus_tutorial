; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pandora+ RPG Tutorial"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Pandora="*res://addons/pandora/api.gd"
PPCombatCalculator="*res://addons/pandora_plus/autoloads/PPCombatCalculator.gd"
PPInventoryUtils="*res://addons/pandora_plus/autoloads/PPInventoryUtils.gd"
PPRecipeUtils="*res://addons/pandora_plus/autoloads/PPRecipeUtils.gd"
PPQuestUtils="*res://addons/pandora_plus/autoloads/PPQuestUtils.gd"
PPNPCUtils="*res://addons/pandora_plus/autoloads/PPNPCUtils.gd"
PPPlayerManager="*res://addons/pandora_plus/managers/player_manager.gd"
PPQuestManager="*res://addons/pandora_plus/managers/quest_manager.gd"
PPNPCManager="*res://addons/pandora_plus/managers/npc_manager.gd"
PPTimeManager="*res://addons/pandora_plus/managers/time_manager.gd"
PPSaveManager="*res://addons/pandora_plus/save_system/save_manager.gd"
Globals="*res://utils/Globals.gd"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/pandora/plugin.cfg", "res://addons/pandora_plus/plugin.cfg")

[input]

toggle_inventory={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":73,"key_label":0,"unicode":105,"location":0,"echo":false,"script":null)
]
}
toggle_quests={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":79,"key_label":0,"unicode":111,"location":0,"echo":false,"script":null)
]
}

[pandora]

config/extensions=[&"res://pandora/extensions", &"res://addons/pandora_plus/extensions"]

[pandora_plus]

config/save_system/max_save_slots=1
config/save_system/autosave_enabled=false
config/player/max_inventory_slots=20

[rendering]

textures/canvas_textures/default_texture_filter=0
